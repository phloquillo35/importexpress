generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String     @id
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Distributor {
  id       String    @id
  name     String
  contact  String?
  website  String?
  notes    String?
  products Product[]
  bulks    Bulk[]
  orders   Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String      @id
  name          String
  slug          String      @unique
  description   String?
  specs         Json?
  images        Json?
  priceUSD      Float
  priceARS      Float?
  costUSD       Float?
  costUSDT      Float?
  yoniEnabled   Boolean     @default(false)
  yoniPercentage Float       @default(25)
  hasFinancing  Boolean     @default(false)
  shippingCost  Float       @default(0)
  profitType    String      @default("percentage")
  profitValue   Float       @default(0)
  finalPriceUSD Float       @default(0)
  finalPriceARS Float       @default(0)
  stock         Int         @default(0)
  minStock      Int         @default(5)
  isAvailable   Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  categoryId    String?
  distributorId String?
  category      Category?      @relation(fields: [categoryId], references: [id])
  distributor   Distributor?   @relation(fields: [distributorId], references: [id])
  orderItems    OrderItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Order {
  id            String      @id
  clientName    String
  clientSurname String      @default("")
  clientPhone   String      @default("")
  clientEmail   String      @default("")
  clientContact String
  distributorId String?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  items         OrderItem[]
  totalUSD      Float
  totalARS      Float?
  status        String      @default("pending")
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id             String  @id
  orderId        String
  productId      String
  quantity       Int
  priceUSD       Float
  bulkId         String?
  trackingCode   String?
  shippingStatus String  @default("pending")
  bulkType       String?
  order          Order   @relation(fields: [orderId], references: [id])
  product        Product @relation(fields: [productId], references: [id])
  bulk           Bulk?   @relation(fields: [bulkId], references: [id])
}

model Bulk {
  id            String      @id
  type          String      @default("grande")
  courier       String      @default("buspack")
  trackingCode  String?
  totalCostUSD  Float       @default(0)
  totalCostARS  Float?
  date          DateTime    @default(now())
  status        String      @default("pending")
  notes         String?
  products      Json
  orderItems    OrderItem[]
  distributorId String?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Transaction {
  id        String   @id
  type      String
  concept   String
  amountUSD Float
  amountARS Float?
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id
  key   String @unique
  value String
}
